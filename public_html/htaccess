# ============================================================
# STRATEDGE — .htaccess principal
# ============================================================

Options -Indexes
Options -MultiViews

# Forcer HTTPS
RewriteEngine On
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Bloquer accès direct au dossier includes
RewriteRule ^includes/ - [F,L]

# Bloquer accès direct aux uploads PHP
RewriteRule ^uploads/.*\.php$ - [F,L]

# Page admin sécurisée (URL secrète)
RewriteRule ^panel-x9k3m/?$ admin/index.php [L]
RewriteRule ^panel-x9k3m/(.*)$ admin/$1 [L]

# Sécurité headers
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
    Header always set Content-Security-Policy "default-src 'self' https:; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://fonts.googleapis.com https://script.starpass.fr https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://fonts.gstatic.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://api.anthropic.com; frame-src https://script.starpass.fr;"
    # Supprimer header serveur révélant la version PHP
    Header always unset X-Powered-By
    Header always unset Server
</IfModule>

# Cache images et assets
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/webp "access plus 1 month"
    ExpiresByType text/css "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
</IfModule>

# Bloquer accès aux fichiers sensibles
<FilesMatch "\.(sql|log|env|ini|bak|json|config|lock|dist)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Bloquer accès aux fichiers PHP sensibles à la racine
<FilesMatch "^(nowpayments-ipn|nowpayments-config|activate_debug)\.php$">
    Order allow,deny
    Deny from all
</FilesMatch>
